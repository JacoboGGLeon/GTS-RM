{
  "name": "base_cp20",
  "checkpoint": "CP24",
  "baseline": "CP20",
  "architecture_family": "global",
  "supported_architectures": ["mlp", "mlp_vae", "rnn", "rnn_bi"],
  "model_inputs": ["y_context", "x_history", "x_future", "x_static"],
  "output": "y_pred",
  "latent": "history_embedding",
  "primary_metric": "robust_macro_mase",
  "config_source_of_truth": "MAC3_TEST/configs",
  "config_loader": "gts_rm.config.load_mac3_config_bundle",
  "migrated_configs": [
    "stage_cp20.json",
    "training_smoke.json",
    "candidates_smoke.json",
    "notebooks_mac3.json",
    "smoke_global_mlp.json",
    "smoke_global_mlp_vae.json",
    "smoke_global_rnn.json",
    "smoke_global_rnn_bi.json"
  ],
  "facade_modules": [
    "gts_rm.config",
    "gts_rm.data",
    "gts_rm.models",
    "gts_rm.training",
    "gts_rm.evaluation",
    "gts_rm.artifacts"
  ],
  "feature_flags": {
    "use_causal_scaler": true,
    "use_observed_mask": false,
    "use_context_mask": false,
    "use_patch_tokenizer": false,
    "use_calendar_encoder": true,
    "use_calendar_future": true,
    "use_static_context": true,
    "use_local_residual_decoder": false,
    "use_quantile_head": false,
    "use_self_supervised_pretraining": false,
    "use_auxiliary_autoencoder": true
  }
}
